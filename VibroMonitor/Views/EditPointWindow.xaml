<Window x:Class="VibroMonitor.Views.EditPointWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="480"
        Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Title="Редактирование точки">

    <Grid Margin="20">
        <Border Padding="12" Background="{StaticResource CardBackground}" BorderBrush="{StaticResource BorderBrushModern}" BorderThickness="1">
            <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Имя -->
        <TextBlock Text="Имя" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" />

        <TextBox Grid.Row="1"
                 Margin="0,5,0,15"
                 Text="{Binding Point.Name}"/>

        <!-- MQTT -->
        <TextBlock Grid.Row="2" Text="MQTT Topic" Foreground="DarkRed" />

        <TextBox Grid.Row="3"
                 Margin="0,5,0,15"
                 Text="{Binding Point.MqttTopic}"/>

        <!-- Thresholds -->
        <Grid Grid.Row="4" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="HiHi"/>
                <TextBox Margin="0,5,8,10" Text="{Binding Point.HiHi, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F2}}" Height="35" />

                <TextBlock Text="Hi"/>
                <TextBox Margin="0,5,8,0" Text="{Binding Point.Hi, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F2}}" Height="35" />
            </StackPanel>

            <StackPanel Grid.Column="1">
                <TextBlock Text="Lo"/>
                <TextBox Margin="0,5,0,10" Text="{Binding Point.Lo, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F2}}" Height="35" />

                <TextBlock Text="LoLo"/>
                <TextBox Margin="0,5,0,0" Text="{Binding Point.LoLo, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F2}}" Height="35" />
            </StackPanel>
        </Grid>

        <!-- Unit -->
        <TextBlock Grid.Row="5" Text="Единицы измерения" Foreground="{StaticResource TextPrimary}" />

        <TextBox Grid.Row="6"
                 Margin="0,5,0,15"
                 Height="35"
                 VerticalAlignment="Top"
                 Text="{Binding Point.Unit}"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="7"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">

            <Button Width="100"
                    Height="35"
                    Margin="0,0,10,0"
                    Content="OK"
                    Command="{Binding SaveCommand}"
                    Background="{StaticResource PrimaryBrush}"/>

            <Button Width="100"
                    Height="35"
                    Content="Отмена"
                    Command="{Binding CancelCommand}"
                    Background="{StaticResource BorderBrushModern}" Foreground="{StaticResource TextPrimary}"/>

        </StackPanel>

        </Grid>
        </Border>
    </Grid>

</Window>