<Window x:Class="VibroMonitor.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VibroMonitor"
        mc:Ignorable="d"
        Title="MainWindow" Height="1080" Width="1920">
    <Grid Margin="8">

        <Grid.RowDefinitions>
            <!-- Верхняя часть -->
            <RowDefinition Height="*" />

            <!-- Нижняя часть -->
            <RowDefinition Height="260" />
        </Grid.RowDefinitions>

        <!-- ===================== -->
        <!-- ВЕРХНЯЯ ЧАСТЬ -->
        <!-- ===================== -->

        <Grid Grid.Row="0">

            <!-- Кнопка настроек -->
            <Button Width="42"
                    Height="42"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,0,6,0"
                    Cursor="Hand"
                    FontSize="18"
                    
                    Content="⚙"
                    Command="{Binding OpenSettingsCommand}"/>

            <!-- Скролл объектов -->
            <ScrollViewer Margin="0,0,0,10"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">

                <ItemsControl ItemsSource="{Binding EquipmentItems}">

                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>

                            <!-- Кликабельная карточка -->
                            <Button Width="500"
                                    Height="220"
                                    Margin="12"
                                    Cursor="Hand"
                                    BorderThickness="3"
                                    Background="White"
                                    Command="{Binding DataContext.OpenEquipmentCommand,
                                    RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}">

                                <Grid>

                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="35"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- Название -->
                                    <TextBlock Grid.Row="0"
                                               Text="{Binding Name}"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>

                                    <!-- Картинка -->
                                    <Border Grid.Row="1"
                                            Margin="10"
                                            BorderBrush="Black"
                                            BorderThickness="2" MinHeight="100" MinWidth="100">

                                        <Image Source="{Binding ImagePath}"
                                               Stretch="Uniform" MinHeight="100" MinWidth="100"/>
                                    </Border>

                                </Grid>
                            </Button>

                        </DataTemplate>
                    </ItemsControl.ItemTemplate>

                </ItemsControl>

            </ScrollViewer>

        </Grid>

        <!-- ===================== -->
        <!-- НИЖНЯЯ ЧАСТЬ -->
        <!-- ===================== -->

        <Border Grid.Row="1"
                BorderBrush="Black"
                BorderThickness="2"
                Background="White">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Заголовки -->
                <Grid Grid.Row="0"
                      Background="#DCDCDC">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="140"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Сообщение"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               Margin="10,0"/>

                    <TextBlock Grid.Column="1"
                               Text="Статус"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               Margin="10,0"/>

                    <TextBlock Grid.Column="2"
                               Text="Время появления"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               Margin="10,0"/>

                    <TextBlock Grid.Column="3"
                               Text="Время квитирования"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               Margin="10,0"/>

                    <TextBlock Grid.Column="4"
                               Text="Датчик"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               Margin="10,0"/>

                </Grid>

                <!-- Таблица -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto">

                    <ItemsControl ItemsSource="{Binding AlarmItems}">

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>

                                <Border BorderBrush="#BDBDBD"
                                        BorderThickness="0,0,0,1">

                                    <Grid Height="48">

                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="3*"/>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="140"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Сообщение -->
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Message}"
                                                   VerticalAlignment="Center"
                                                   Margin="10,0"
                                                   TextWrapping="Wrap"/>

                                        <!-- Статус -->
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Status}"
                                                   VerticalAlignment="Center"
                                                   Margin="10,0"/>

                                        <!-- Время появления -->
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Created}"
                                                   VerticalAlignment="Center"
                                                   Margin="10,0"/>

                                        <!-- Время квитирования -->
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding Acknowledged}"
                                                   VerticalAlignment="Center"
                                                   Margin="10,0"/>

                                        <!-- Датчик -->
                                        <TextBlock Grid.Column="4"
                                                   Text="{Binding Sensor}"
                                                   VerticalAlignment="Center"
                                                   Margin="10,0"/>

                                        <!-- Кнопка -->
                                        <Button Grid.Column="5"
                                        Width="120"
                                        Height="32"
                                        Content="Квитировать"
                                        Command="{Binding DataContext.AckAlarmCommand,
                                                          RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"/>
                                    </Grid>

                                </Border>

                            </DataTemplate>
                        </ItemsControl.ItemTemplate>

                    </ItemsControl>

                </ScrollViewer>

            </Grid>

        </Border>

    </Grid>
</Window>
