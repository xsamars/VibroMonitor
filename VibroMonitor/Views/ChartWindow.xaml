<Window x:Class="VibroMonitor.Views.ChartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        Title="График"
        Width="1200"
        Height="700">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="8" Grid.Row="0">
            <TextBlock VerticalAlignment="Center" Text="Интервал: " Margin="0,0,6,0" />
            <ComboBox Width="160" SelectedValuePath="Tag" SelectedValue="{Binding SelectedRange, Mode=TwoWay}" IsSynchronizedWithCurrentItem="False">
                <ComboBoxItem Tag="Hour">1 час</ComboBoxItem>
                <ComboBoxItem Tag="Day">1 день</ComboBoxItem>
                <ComboBoxItem Tag="Week">1 неделя</ComboBoxItem>
                <ComboBoxItem Tag="Month">1 месяц</ComboBoxItem>
                <ComboBoxItem Tag="All">Все</ComboBoxItem>
            </ComboBox>
        </StackPanel>

        <lvc:CartesianChart x:Name="Chart" Series="{Binding Series}" Grid.Row="1" ZoomMode="Both">
            <lvc:CartesianChart.XAxes>
            <lvc:AxesCollection>
                    <lvc:XamlAxis
                    Labeler="{Binding XLabeler}"
                    CrosshairLabelsBackground="#FF8C00"
                    CrosshairLabelsPaint="#8B0000"
                    CrosshairPaint="#FF8C00"
                    CrosshairSnapEnabled="True"/>
                </lvc:AxesCollection>
            </lvc:CartesianChart.XAxes>

            <lvc:CartesianChart.YAxes>
                <lvc:AxesCollection>
                    <lvc:XamlAxis
                    MinLimit="0"
                    CrosshairLabelsBackground="#FF8C00"
                    CrosshairLabelsPaint="#8B0000"
                    CrosshairPaint="#FF8C00"
                    CrosshairSnapEnabled="True"/>
                </lvc:AxesCollection>
            </lvc:CartesianChart.YAxes>
        </lvc:CartesianChart>

    </Grid>

</Window>