<Window x:Class="VibroMonitor.Views.EquipmentDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:VibroMonitor.Models"
        mc:Ignorable="d"
        WindowState="Maximized"
        Background="#ECECEC"
        Title="Объект" Width="1800" Height="900" ResizeMode="NoResize" WindowStartupLocation="CenterScreen">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="250" />
        </Grid.RowDefinitions>

        <!-- ВЕРХ -->
        <Grid Grid.Row="0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="350" />
            </Grid.ColumnDefinitions>

            <!-- КАРТИНКА -->
            <Border Grid.Column="0"
                    BorderBrush="Black"
                    BorderThickness="2"
                    Background="White">

                <Grid>

                    <!-- Картинка -->
                    <Image Source="{Binding Equipment.ImagePath}"
                           Stretch="Uniform"/>

                    <!-- Слой точек -->
                    <Canvas Background="Transparent"
                            MouseLeftButtonDown="Canvas_MouseLeftButtonDown">

                        <ItemsControl ItemsSource="{Binding Equipment.Points}">

                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left"
                                            Value="{Binding X}"/>

                                    <Setter Property="Canvas.Top"
                                            Value="{Binding Y}"/>
                                </Style>
                            </ItemsControl.ItemContainerStyle>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:EquipmentPoint}">

                                    <Button Width="14"
                                            Height="14"
                                            Background="Red"
                                            BorderBrush="White"
                                            BorderThickness="2"
                                            Cursor="Hand"
                                            Tag="{Binding DataContext,RelativeSource={RelativeSource AncestorType=Window}}"
                                            Command="{Binding DataContext.OpenChartCommand,
                                                            RelativeSource={RelativeSource AncestorType=Window}}"

                                            CommandParameter="{Binding}">
                                        <Button.ContextMenu>
                                            <ContextMenu>

                                                <MenuItem Header="Редактировать"
                                                      Command="{Binding PlacementTarget.Tag.EditPointCommand,RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding}" />

                                                <MenuItem Header="Удалить"
                                                      Command="{Binding PlacementTarget.Tag.RemovePointCommand,RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding}" />

                                            </ContextMenu>
                                        </Button.ContextMenu>

                                        <Button.ToolTip>

                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="Bold"/>

                                                <TextBlock Text="{Binding Value}"/>

                                                <TextBlock Text="{Binding Unit}"/>
                                            </StackPanel>

                                        </Button.ToolTip>

                                    </Button>

                                </DataTemplate>
                            </ItemsControl.ItemTemplate>

                        </ItemsControl>

                    </Canvas>

                </Grid>

            </Border>

            <!-- ПРАВАЯ ПАНЕЛЬ -->
            <Border Grid.Column="1"
                    Margin="10,0,0,0"
                    BorderBrush="Black"
                    BorderThickness="2"
                    Background="White">
                
                <Grid Margin="10">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid ColumnDefinitions="*, Auto">
                        <ToggleButton Width="40"
                          Height="40"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Top"
                          Grid.Column="1"
              
                          Margin="0,0,10,10"
                          IsChecked="{Binding IsEditMode}">

                            <TextBlock Text="✎"/>
                        </ToggleButton>

                        <TextBlock Text="{Binding Equipment.Name}"
                               FontSize="28"
                               HorizontalAlignment="Left"
                               FontWeight="Bold"
                               Grid.Column="0"
                               Margin="0,0,0,15"/>
                    </Grid>
                    

                    <!-- СПИСОК ТОЧЕК -->
                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding Equipment.Points}"
                             Tag="{Binding}"
                             SelectedItem="{Binding SelectedPoint}"
                             ScrollViewer.VerticalScrollBarVisibility="Hidden">

                        <ListBox.ItemTemplate>

                            <DataTemplate>

                                <Border Padding="10"
                                        Margin="0,0,0,8"
                                        BorderBrush="#CCCCCC"
                                        BorderThickness="1" Width="302">
                                    <Border.ContextMenu>

                                        <ContextMenu>

                                            <MenuItem Header="Редактировать"
                                                  Command="{Binding PlacementTarget.Tag.EditPointCommand,
                                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding}" />

                                            <MenuItem Header="Удалить"
                                                  Command="{Binding PlacementTarget.Tag.RemovePointCommand,
                                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding}" />

                                        </ContextMenu>

                                    </Border.ContextMenu>
                                    <StackPanel>

                                        <TextBlock Text="{Binding Name}"
                                                   FontWeight="Bold"
                                                   FontSize="16"/>

                                        <TextBlock Text="{Binding Value,
                                                                  StringFormat=Значение: {0}}"/>

                                        <TextBlock Text="{Binding Unit,
                                                                  StringFormat=Ед.: {0}}"/>

                                        <TextBlock Text="{Binding X,
                                                                  StringFormat=X: {0:F0}}"/>

                                        <TextBlock Text="{Binding Y,
                                                                  StringFormat=Y: {0:F0}}"/>

                                    </StackPanel>

                                </Border>

                            </DataTemplate>

                        </ListBox.ItemTemplate>

                    </ListBox>

                </Grid>

            </Border>

        </Grid>

        <!-- ЖУРНАЛ -->
        <DataGrid Grid.Row="1"
                  Margin="0,10,0,0"
                  AutoGenerateColumns="False"
                  ItemsSource="{Binding Equipment.Alarms}">

            <DataGrid.Columns>

                <DataGridTextColumn Header="Сообщение"
                                    Binding="{Binding Message}"
                                    Width="*"/>

                <DataGridTextColumn Header="Статус"
                                    Binding="{Binding Status}"
                                    Width="150"/>

                <DataGridTextColumn Header="Время"
                                    Binding="{Binding Created}"
                                    Width="200"/>

                <DataGridTextColumn Header="Датчик"
                                    Binding="{Binding Sensor}"
                                    Width="250"/>

            </DataGrid.Columns>

        </DataGrid>

    </Grid>

</Window>